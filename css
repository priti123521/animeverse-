.home-hidden .main-content {
    margin-left: 0;
}

.home-toggle {
    margin: 10px;
    padding: 8px;
    background: #222;
    color: white;
    border: 1px solid #444;
    cursor: pointer;
}

.dashboard-page { display: none; }
.dashboard-page.active-page { display: block; }

.card {
    background: #1a1a1a;
    padding: 15px;
    margin: 10px 0;
    border-radius: 8px;
    color: white;
}